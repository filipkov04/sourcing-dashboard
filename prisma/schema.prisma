// Sourcing Dashboard - Database Schema
// This defines all the data structures for the application

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTHENTICATION & USERS
// ============================================

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  emailVerified DateTime?
  name          String?
  password      String?      // hashed with bcrypt
  image         String?
  avatarId      String?      // preset avatar: "avatar-1" through "avatar-7"
  role          UserRole     @default(MEMBER)

  // Active project
  activeProjectId String?
  activeProject   Project? @relation("ActiveProject", fields: [activeProjectId], references: [id], onDelete: SetNull)

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitationsSent UserInvitation[] @relation("InvitedByUser")
  notificationPreference NotificationPreference?

  // Chat relations
  conversations  ConversationParticipant[]
  messagesSent   Message[]
  presence       UserPresence?

  // Request relations
  requestsCreated  Request[] @relation("RequestsCreated")
  requestsReviewed Request[] @relation("RequestsReviewed")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
}

enum UserRole {
  OWNER   // Can manage billing, delete org
  ADMIN   // Can manage users, factories
  MEMBER  // Can view and edit orders
  VIEWER  // Read-only access
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ============================================
// CORE ENTITIES
// ============================================

model Organization {
  id   String @id @default(cuid())
  name String
  slug String @unique // for URLs: /org/acme-fashion
  logo String?

  // Relations
  users         User[]
  projects      Project[]
  factories     Factory[]
  orders        Order[]
  invitations   UserInvitation[]
  alerts        Alert[]
  conversations Conversation[]
  requests      Request[]
  customCharts  CustomChart[]
  chartFolders  ChartFolder[]
  savedReports  SavedReport[]

  // Inventory & Products
  products           Product[]
  inventoryLocations InventoryLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  slug           String
  description    String?
  color          String?  // hex color for card/badge
  icon           String?  // emoji or icon name
  startDate      DateTime?
  endDate        DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  factories      Factory[]
  orders         Order[]
  alerts         Alert[]
  conversations  Conversation[]
  requests       Request[]
  customCharts   CustomChart[]
  chartFolders   ChartFolder[]
  savedReports   SavedReport[]
  integrations   Integration[]

  // Inventory & Products
  products           Product[]
  inventoryLocations InventoryLocation[]

  activeUsers    User[] @relation("ActiveProject")

  createdById    String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model UserInvitation {
  id             String           @id @default(cuid())
  email          String
  role           UserRole         @default(MEMBER)
  token          String           @unique @default(uuid())
  status         InvitationStatus @default(PENDING)

  // Relations
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedById    String
  invitedBy      User             @relation("InvitedByUser", fields: [invitedById], references: [id], onDelete: Cascade)

  // Dates
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([email, organizationId])
  @@index([token])
}

model Factory {
  id       String @id @default(cuid())
  name     String
  location String // "Guangzhou, China"
  address  String? @db.Text
  latitude  Float?
  longitude Float?

  // Contact info
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Intelligence fields
  verificationStatus VerificationStatus @default(UNVERIFIED)
  categories         String[]           // ["Knitwear", "Wovens"]
  capabilities       String[]           // ["Screen Print", "Embroidery"]
  moqMin             Int?
  leadTimeDays       Int?
  reliabilityScore   Float?             // 0-100
  riskLevel          RiskLevel          @default(LOW)
  isPreferred        Boolean            @default(false)
  displayPrecision   DisplayPrecision   @default(EXACT)
  lastQcAt           DateTime?

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  orders         Order[]
  alerts         Alert[]
  conversations  Conversation[]
  requests       Request[]
  integrations   Integration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
}

// ============================================
// INTEGRATIONS
// ============================================

enum IntegrationType {
  REST
  SFTP
  WEBHOOK
  MANUAL
  CARRIER_TRACKING
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING
}

enum SyncStatus {
  SUCCESS
  FAILED
  IN_PROGRESS
  NEVER
}

model Integration {
  id             String            @id @default(cuid())
  name           String            // e.g. "Factory ERP API"
  type           IntegrationType
  status         IntegrationStatus @default(PENDING)

  // Encrypted credentials stored as JSON (task 6.11)
  credentials    Json?

  // Type-specific config (base URL, SFTP path, field mappings, etc.)
  config         Json?

  // Sync settings
  syncFrequency  Int               @default(15) // minutes between syncs
  lastSyncAt     DateTime?
  lastSyncStatus SyncStatus        @default(NEVER)
  lastSyncError  String?           @db.Text

  // Relations
  factoryId      String
  factory        Factory           @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  organizationId String
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([factoryId])
  @@index([organizationId, status])
  @@index([projectId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String?     // Brand's PO number (optional for auto-created orders)
  productName     String
  productSKU      String?
  productImage    String?     // Supabase Storage public URL for product image
  quantity        Int
  unit            String      @default("pieces") // pieces, meters, kg
  overallProgress Int         @default(0) // 0-100
  status          OrderStatus @default(PENDING)

  // Dates
  expectedStartDate  DateTime  @map("orderDate")
  placedDate         DateTime?
  expectedDate       DateTime
  actualDate         DateTime?

  // Additional info
  notes    String?   @db.Text
  priority Priority  @default(NORMAL)
  tags     String[]  // ["urgent", "sample", "production"]

  // Carrier tracking
  trackingNumber    String?
  carrier           String?           // "DHL", "Maersk", "CMA CGM" (auto-detected or manual)
  carrierCode       String?           // 17Track carrier code (e.g. "2151")
  shippingMethod    ShippingMethod?
  currentLat        Float?
  currentLng        Float?
  currentLocation   String?           // "Port of Shanghai, CN"
  estimatedArrival  DateTime?
  lastTrackingSync  DateTime?
  trackingStatus    TrackingStatus?

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  factoryId      String
  factory        Factory      @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  stages         OrderStage[]
  events         OrderEvent[]
  adminNotes     StageAdminNote[]
  attachments    OrderAttachment[]
  comments       OrderComment[]
  alerts         Alert[]
  conversations  Conversation[]
  requests       Request[]
  trackingEvents TrackingEvent[]

  // Recurrence
  recurrenceEnabled      Boolean   @default(false)
  recurrenceIntervalDays Int?      // 30, 60, 90, 120, or custom
  recurrenceNextDate     DateTime? // computed from interval OR manually overridden
  recurrenceLastAlertAt  DateTime? // prevents duplicate reminder alerts

  // Auto-reorder
  autoReorder              Boolean   @default(false)
  autoReorderOrderNumber   String?
  autoReorderStartDate     DateTime?
  autoReorderEndDate       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Partial unique index enforced via raw SQL (WHERE orderNumber IS NOT NULL)
  // @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([projectId])
  @@index([factoryId])
  @@index([status])
  @@index([expectedDate])
}

enum OrderStatus {
  PENDING          // Order placed, not started
  IN_PROGRESS      // Production started
  BEHIND_SCHEDULE  // Projected to finish late based on stage timeline slippage
  DELAYED          // Behind schedule (one or more stages delayed)
  DISRUPTED        // Production blocked (one or more stages blocked)
  COMPLETED   // Production complete
  SHIPPED     // Shipped to brand
  IN_TRANSIT  // Carrier confirms movement
  CUSTOMS     // Held at customs
  DELIVERED   // Received by brand
  CANCELLED   // Order cancelled
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ShippingMethod {
  OCEAN
  AIR
  ROAD
  RAIL
  MULTIMODAL
}

enum TrackingStatus {
  NOT_FOUND
  INFO_RECEIVED
  IN_TRANSIT
  CUSTOMS
  EXCEPTION
  DELIVERED
  EXPIRED
}

enum VerificationStatus {
  VERIFIED
  UNVERIFIED
  PENDING
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DisplayPrecision {
  EXACT
  APPROXIMATE
  CITY_LEVEL
}

model OrderStage {
  id       String      @id @default(cuid())
  orderId  String
  order    Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name     String      // "Cutting", "Sewing", "Quality Check"
  sequence Int         // Order of stages: 1, 2, 3
  progress Int         @default(0) // 0-100
  status   StageStatus @default(NOT_STARTED)

  // Dates
  startedAt         DateTime?
  completedAt       DateTime?
  expectedStartDate DateTime?
  expectedEndDate   DateTime?
  notes             String?   @db.Text

  // Flexible key-value metadata per stage (e.g. responsible person, sample count, cost breakdown)
  metadata    Json?     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, sequence])
  @@index([orderId])
}

enum StageStatus {
  NOT_STARTED
  IN_PROGRESS
  BEHIND_SCHEDULE  // Stage still progressing but past expected end date (amber)
  COMPLETED
  SKIPPED
  DELAYED          // Stage has stalled / no longer progressing (orange)
  BLOCKED          // Stage is completely disrupted/stopped (red)
}

// ============================================
// CARRIER TRACKING EVENTS
// ============================================

model TrackingEvent {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  timestamp       DateTime        // carrier event time
  location        String?         // "Shanghai, CN"
  latitude        Float?
  longitude       Float?
  description     String          // "Departed port of origin"
  statusCode      String?         // raw carrier status code
  trackingStatus  TrackingStatus
  source          String          @default("17track")
  rawData         Json?
  createdAt       DateTime        @default(now())

  @@index([orderId, timestamp])
  @@index([orderId])
}

// ============================================
// HISTORY & AUDIT TRACKING
// ============================================

model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stageId     String?  // Nullable - only set for stage-level changes
  eventType   String   // STATUS_CHANGE, PROGRESS_CHANGE, FIELD_CHANGE, NOTE_CHANGE, STAGE_ADDED, STAGE_REMOVED
  field       String?  // Which field changed (e.g., "status", "progress", "expectedDate", "priority")
  oldValue    String?  // Previous value (as string)
  newValue    String?  // New value (as string)
  stageName   String?  // For stage events, store the stage name for display
  createdAt   DateTime @default(now())

  @@index([orderId, createdAt])
}

// ============================================
// ADMIN NOTES (Stage-level admin details)
// ============================================

model StageAdminNote {
  id          String        @id @default(cuid())
  stageId     String
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type        AdminNoteType @default(NOTE)
  content     String        @db.Text
  authorId    String
  authorName  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([stageId, createdAt])
  @@index([orderId])
}

enum AdminNoteType {
  NOTE
  COMMENT
  STATUS_DETAIL
  CHANGE_LOG
  DELAY_REASON    // Submitted by MEMBER+ when stage is DELAYED/BLOCKED
}

// ============================================
// FILE ATTACHMENTS
// ============================================

model OrderAttachment {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileName     String
  fileType     String   // MIME type
  fileSize     Int      // bytes
  storagePath  String   // path in Supabase Storage bucket
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([orderId])
}

// ============================================
// ORDER COMMENTS (Team discussion)
// ============================================

model OrderComment {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  authorId   String
  authorName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orderId, createdAt])
}

// ============================================
// ALERTS & NOTIFICATIONS
// ============================================

model Alert {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Alert details
  title           String
  message         String   @db.Text
  severity        Severity @default(INFO)

  // Related entities (optional)
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  factoryId       String?
  factory         Factory? @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  conversationId  String?
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  // Status
  read            Boolean  @default(false)
  resolved        Boolean  @default(false)
  resolvedAt      DateTime?
  resolvedBy      String?

  createdAt       DateTime @default(now())

  @@index([organizationId, read])
  @@index([organizationId, createdAt])
  @@index([projectId])
  @@index([orderId])
  @@index([factoryId])
  @@index([conversationId])
}

enum Severity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// ============================================
// NOTIFICATION PREFERENCES
// ============================================

model NotificationPreference {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderStatusEnabled      Boolean  @default(true)
  delayAlertEnabled       Boolean  @default(true)
  disruptionAlertEnabled  Boolean  @default(true)
  weeklyDigestEnabled     Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ============================================
// CHAT & MESSAGING
// ============================================

model Conversation {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Participants
  participants    ConversationParticipant[]
  messages        Message[]
  alerts          Alert[]

  // Optional: Link to specific order or factory
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  factoryId       String?
  factory         Factory? @relation(fields: [factoryId], references: [id], onDelete: SetNull)

  // Chat type & category
  type            ConversationType @default(GENERAL)
  category        String?

  // Metadata
  name            String?
  subject         String?
  lastMessageAt   DateTime?

  // Request relation
  request         Request?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Read status
  lastReadAt      DateTime?
  unreadCount     Int      @default(0)

  // Notification preferences for this conversation
  muted           Boolean  @default(false)
  pinned          Boolean  @default(false)
  notifyReplies   Boolean  @default(true)
  notifyMentions  Boolean  @default(true)

  // Typing indicator — updated on each keystroke, considered "typing" if within last 3s
  typingAt        DateTime?

  createdAt       DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId        String?
  sender          User?    @relation(fields: [senderId], references: [id])

  content         String   @db.Text
  messageType     MessageType @default(TEXT)

  // For request approvals
  requestAction   RequestAction?

  // Threading
  parentId        String?
  parent          Message?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies         Message[] @relation("MessageThread")
  threadCount     Int       @default(0)

  // Soft delete
  deletedAt       DateTime?

  // Pinning
  pinnedAt        DateTime?
  pinnedById      String?

  // Forwarding
  forwardedFromId String?
  forwardedFrom   Message?  @relation("MessageForward", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwards        Message[] @relation("MessageForward")

  // Read tracking
  readBy          MessageRead[]

  // Reactions
  reactions       MessageReaction[]

  // File attachments
  attachments     MessageAttachment[]

  createdAt       DateTime @default(now())
  editedAt        DateTime?

  @@index([conversationId])
  @@index([createdAt])
  @@index([parentId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String

  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model MessageAttachment {
  id           String   @id @default(cuid())
  messageId    String
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName     String
  fileType     String
  fileSize     Int
  storagePath  String
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([messageId])
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
}

enum MessageType {
  TEXT            // Regular text message
  SYSTEM          // System-generated (e.g., "User joined")
  REQUEST         // Request notification
  APPROVAL        // Approval/rejection of request
  BOT             // Bot-generated message (Sourcy Agent)
}

enum ConversationType {
  GENERAL         // Default team chat
  SUPPORT         // Support chat with Sourcy Agent
  FACTORY         // Factory communication
  DIRECT          // 1:1 direct messages
}

enum RequestAction {
  APPROVED
  REJECTED
  PENDING_INFO    // Admin needs more information
}

// EMAIL LOGGING
// ============================================

model EmailLog {
  id        String   @id @default(cuid())
  toEmail   String
  fromEmail String
  subject   String
  status    String   // SENT, FAILED
  resendId  String?
  error     String?
  sentAt    DateTime @default(now())
}

// ============================================
// USER PRESENCE
// ============================================

model UserPresence {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeen      DateTime @default(now())
  status        String?  // null = auto-detect, "online"/"away"/"busy" = manual override
  customMessage String?  // Slack-style status text (max 100 chars)

  @@index([lastSeen])
}

// ============================================
// REQUESTS (Order/Factory approval workflow)
// ============================================

enum RequestType {
  ORDER_REQUEST
  FACTORY_REQUEST
  ORDER_EDIT_REQUEST
  FACTORY_EDIT_REQUEST
  ORDER_DELETE_REQUEST
  FACTORY_DELETE_REQUEST
}

enum RequestStatus {
  PENDING
  IN_REVIEW
  NEEDS_INFO
  APPROVED
  REJECTED
  CANCELLED
}

model Request {
  id              String        @id @default(cuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  requesterId     String
  requester       User          @relation("RequestsCreated", fields: [requesterId], references: [id])

  type            RequestType
  status          RequestStatus @default(PENDING)
  data            Json          // Stores order/factory form data as flexible JSON

  // Review
  reviewedById    String?
  reviewedBy      User?         @relation("RequestsReviewed", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  reviewNote      String?       @db.Text

  // Target entities (created after approval for CREATE, or referenced for EDIT/DELETE)
  targetOrderId   String?
  targetOrder     Order?   @relation(fields: [targetOrderId], references: [id], onDelete: SetNull)
  targetFactoryId String?
  targetFactory   Factory? @relation(fields: [targetFactoryId], references: [id], onDelete: SetNull)

  // Chat thread
  conversationId  String?  @unique
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, status])
  @@index([projectId])
  @@index([requesterId])
}

// ============================================
// CUSTOM CHARTS
// ============================================

enum ChartType {
  BAR
  LINE
  PIE
  AREA
  RADAR
  STACKED_BAR
}

enum ChartVisibility {
  PERSONAL
  SHARED
}

model CustomChart {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creatorId      String
  title          String
  chartType      ChartType
  dataSource     String          // e.g. "status-breakdown", "trends", "lead-time"
  metric         String          // e.g. "ordersByStatus", "ordersOverTime"
  config         Json            // axes, colors, filters, dateRange, showTrendLine
  visibility     ChartVisibility @default(PERSONAL)
  sortOrder      Int             @default(0)
  folderId       String?
  folder         ChartFolder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  annotations    ChartAnnotation[]
  reportCharts   ReportChart[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, visibility])
  @@index([projectId])
  @@index([creatorId])
  @@index([folderId])
}

model ChartFolder {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creatorId      String
  name           String
  color          String?      // hex color for folder accent
  sortOrder      Int          @default(0)
  charts         CustomChart[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([creatorId])
}

model ChartAnnotation {
  id         String      @id @default(cuid())
  chartId    String
  chart      CustomChart @relation(fields: [chartId], references: [id], onDelete: Cascade)
  content    String
  color      String      @default("#FF4D15") // orange default
  authorId   String
  authorName String
  createdAt  DateTime    @default(now())

  @@index([chartId])
}

enum ReportSchedule {
  DAILY
  WEEKLY
  MONTHLY
}

model SavedReport {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creatorId      String
  name           String
  description    String?
  schedule       ReportSchedule
  recipients     String[]       // email addresses
  enabled        Boolean        @default(true)
  charts         ReportChart[]
  lastSentAt     DateTime?
  nextSendAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([creatorId])
  @@index([nextSendAt])
}

model ReportChart {
  id         String      @id @default(cuid())
  reportId   String
  report     SavedReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  chartId    String
  chart      CustomChart @relation(fields: [chartId], references: [id], onDelete: Cascade)
  sortOrder  Int         @default(0)

  @@unique([reportId, chartId])
  @@index([reportId])
  @@index([chartId])
}

// ============================================
// INVENTORY & PRODUCTS (Phase 4 — Week 9)
// ============================================

enum RunwayStatus {
  HEALTHY       // >30 days of stock
  WARNING       // 15-30 days
  CRITICAL      // <15 days
  OUT_OF_STOCK
}

enum LocationType {
  WAREHOUSE
  FACTORY
  STORE
  VIRTUAL
}

enum TransactionType {
  RECEIPT        // Receiving stock from supplier
  ADJUSTMENT     // Manual stock correction
  SALE           // Stock sold
  TRANSFER       // Move between locations
  RETURN         // Customer return
  DAMAGE         // Stock damaged/destroyed
  RESERVATION    // Reserve for order
}

model Product {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Product Identity
  sku               String
  name              String
  description       String?  @db.Text
  category          String?

  // Physical Properties
  weight            Float?   // kg
  length            Float?   // cm
  width             Float?   // cm
  height            Float?   // cm
  volumeCBM         Float?   // auto-calculated cubic meters
  isBulkCargo       Boolean  @default(false) // >1 CBM

  // Procurement Data
  cogs              Float?   // Cost of Goods Sold per unit
  currency          String   @default("USD")
  hsCode            String?  // Harmonized System code for customs
  originCountry     String?  // Country of manufacture

  // Inventory Thresholds
  minStock          Int?     // Reorder point
  maxStock          Int?     // Max inventory level
  safetyStock       Int?     // Buffer stock for lead time

  // Sourcing Metadata
  tags              String[] // [supplier, season, material, status]
  leadTimeProdDays  Int?     // Production lead time
  leadTimeShipDays  Int?     // Shipping lead time
  moq               Int?     // Minimum order quantity
  dailySalesEstimate Float?  // Manual estimate of daily sales (units/day), used until real transaction data

  // Relationships
  stockLevels       Stock[]
  transactions      InventoryTransaction[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([organizationId, sku])
  @@index([organizationId, sku])
  @@index([organizationId, category])
  @@index([projectId])
}

model InventoryLocation {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  name              String   // "Main Warehouse", "Factory A", "Store NYC"
  type              LocationType // WAREHOUSE, FACTORY, STORE, VIRTUAL
  address           String?
  isDefault         Boolean  @default(false)

  stockLevels       Stock[]
  transactions      InventoryTransaction[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
}

model Stock {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String?

  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId        String
  location          InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Stock Quantities
  onHand            Int      @default(0)  // Physical stock available
  reserved          Int      @default(0)  // Allocated to orders
  available         Int      @default(0)  // onHand - reserved
  inTransit         Int      @default(0)  // Inbound shipments
  backorder         Int      @default(0)  // Negative stock

  // Value Tracking
  avgCost           Float?   // Weighted average cost
  totalValue        Float?   // onHand * avgCost

  // Calculated Fields
  daysOfStock       Float?   // available / dailySalesVelocity
  runwayStatus      RunwayStatus?

  lastCountDate     DateTime?
  lastCountBy       String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([productId, locationId])
  @@index([organizationId, productId])
  @@index([runwayStatus])
  @@index([projectId])
}

model InventoryTransaction {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String?

  productId         String
  product           Product  @relation(fields: [productId], references: [id])
  locationId        String
  location          InventoryLocation @relation(fields: [locationId], references: [id])

  // Transaction Details
  type              TransactionType
  quantity          Int      // Positive or negative
  reason            String?  // "Damaged", "Lost", "Found", "Cycle Count"
  reference         String?  // PO number, shipment ID, etc.

  // Snapshot
  balanceBefore     Int
  balanceAfter      Int
  costBefore        Float?
  costAfter         Float?

  // Audit
  performedBy       String
  performedAt       DateTime @default(now())
  notes             String?  @db.Text

  @@index([organizationId, productId])
  @@index([organizationId, type])
  @@index([performedAt])
  @@index([projectId])
}
