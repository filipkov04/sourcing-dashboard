// Sourcing Dashboard - Database Schema
// This defines all the data structures for the application

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTHENTICATION & USERS
// ============================================

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  emailVerified DateTime?
  name          String?
  password      String?      // hashed with bcrypt
  image         String?
  avatarId      String?      // preset avatar: "avatar-1" through "avatar-7"
  role          UserRole     @default(MEMBER)

  // Active project
  activeProjectId String?
  activeProject   Project? @relation("ActiveProject", fields: [activeProjectId], references: [id], onDelete: SetNull)

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitationsSent UserInvitation[] @relation("InvitedByUser")
  notificationPreference NotificationPreference?

  // Chat relations
  conversations  ConversationParticipant[]
  messagesSent   Message[]
  presence       UserPresence?

  // Request relations
  requestsCreated  Request[] @relation("RequestsCreated")
  requestsReviewed Request[] @relation("RequestsReviewed")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
}

enum UserRole {
  OWNER   // Can manage billing, delete org
  ADMIN   // Can manage users, factories
  MEMBER  // Can view and edit orders
  VIEWER  // Read-only access
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ============================================
// CORE ENTITIES
// ============================================

model Organization {
  id   String @id @default(cuid())
  name String
  slug String @unique // for URLs: /org/acme-fashion
  logo String?

  // Relations
  users         User[]
  projects      Project[]
  factories     Factory[]
  orders        Order[]
  invitations   UserInvitation[]
  alerts        Alert[]
  conversations Conversation[]
  requests      Request[]
  customCharts  CustomChart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  slug           String
  description    String?
  color          String?  // hex color for card/badge
  icon           String?  // emoji or icon name

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  factories      Factory[]
  orders         Order[]
  alerts         Alert[]
  conversations  Conversation[]
  requests       Request[]
  customCharts   CustomChart[]
  integrations   Integration[]

  activeUsers    User[] @relation("ActiveProject")

  createdById    String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model UserInvitation {
  id             String           @id @default(cuid())
  email          String
  role           UserRole         @default(MEMBER)
  token          String           @unique @default(uuid())
  status         InvitationStatus @default(PENDING)

  // Relations
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedById    String
  invitedBy      User             @relation("InvitedByUser", fields: [invitedById], references: [id], onDelete: Cascade)

  // Dates
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([email, organizationId])
  @@index([token])
}

model Factory {
  id       String @id @default(cuid())
  name     String
  location String // "Guangzhou, China"
  address  String? @db.Text
  latitude  Float?
  longitude Float?

  // Contact info
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  orders         Order[]
  alerts         Alert[]
  conversations  Conversation[]
  request        Request?
  integrations   Integration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
}

// ============================================
// INTEGRATIONS
// ============================================

enum IntegrationType {
  REST
  SFTP
  WEBHOOK
  MANUAL
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING
}

enum SyncStatus {
  SUCCESS
  FAILED
  IN_PROGRESS
  NEVER
}

model Integration {
  id             String            @id @default(cuid())
  name           String            // e.g. "Factory ERP API"
  type           IntegrationType
  status         IntegrationStatus @default(PENDING)

  // Encrypted credentials stored as JSON (task 6.11)
  credentials    Json?

  // Type-specific config (base URL, SFTP path, field mappings, etc.)
  config         Json?

  // Sync settings
  syncFrequency  Int               @default(15) // minutes between syncs
  lastSyncAt     DateTime?
  lastSyncStatus SyncStatus        @default(NEVER)
  lastSyncError  String?           @db.Text

  // Relations
  factoryId      String
  factory        Factory           @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  organizationId String
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([factoryId])
  @@index([organizationId, status])
  @@index([projectId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      // Brand's PO number
  productName     String
  productSKU      String?
  productImage    String?     // Supabase Storage public URL for product image
  quantity        Int
  unit            String      @default("pieces") // pieces, meters, kg
  overallProgress Int         @default(0) // 0-100
  status          OrderStatus @default(PENDING)

  // Dates
  orderDate    DateTime
  expectedDate DateTime
  actualDate   DateTime?

  // Additional info
  notes    String?   @db.Text
  priority Priority  @default(NORMAL)
  tags     String[]  // ["urgent", "sample", "production"]

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  factoryId      String
  factory        Factory      @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  stages         OrderStage[]
  events         OrderEvent[]
  adminNotes     StageAdminNote[]
  attachments    OrderAttachment[]
  comments       OrderComment[]
  alerts         Alert[]
  conversations  Conversation[]
  request        Request?

  // Recurrence
  recurrenceEnabled      Boolean   @default(false)
  recurrenceIntervalDays Int?      // 30, 60, 90, 120, or custom
  recurrenceNextDate     DateTime? // computed from interval OR manually overridden
  recurrenceLastAlertAt  DateTime? // prevents duplicate reminder alerts

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, orderNumber]) // PO numbers unique per org
  @@index([organizationId])
  @@index([projectId])
  @@index([factoryId])
  @@index([status])
  @@index([expectedDate])
}

enum OrderStatus {
  PENDING     // Order placed, not started
  IN_PROGRESS // Production started
  DELAYED     // Behind schedule (one or more stages delayed)
  DISRUPTED   // Production blocked (one or more stages blocked)
  COMPLETED   // Production complete
  SHIPPED     // Shipped to brand
  DELIVERED   // Received by brand
  CANCELLED   // Order cancelled
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model OrderStage {
  id       String      @id @default(cuid())
  orderId  String
  order    Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name     String      // "Cutting", "Sewing", "Quality Check"
  sequence Int         // Order of stages: 1, 2, 3
  progress Int         @default(0) // 0-100
  status   StageStatus @default(NOT_STARTED)

  // Dates
  startedAt         DateTime?
  completedAt       DateTime?
  expectedStartDate DateTime?
  expectedEndDate   DateTime?
  notes             String?   @db.Text

  // Flexible key-value metadata per stage (e.g. responsible person, sample count, cost breakdown)
  metadata    Json?     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, sequence])
  @@index([orderId])
}

enum StageStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
  DELAYED      // Stage is behind schedule (yellow)
  BLOCKED      // Stage is completely disrupted/stopped (red)
}

// ============================================
// HISTORY & AUDIT TRACKING
// ============================================

model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stageId     String?  // Nullable - only set for stage-level changes
  eventType   String   // STATUS_CHANGE, PROGRESS_CHANGE, FIELD_CHANGE, NOTE_CHANGE, STAGE_ADDED, STAGE_REMOVED
  field       String?  // Which field changed (e.g., "status", "progress", "expectedDate", "priority")
  oldValue    String?  // Previous value (as string)
  newValue    String?  // New value (as string)
  stageName   String?  // For stage events, store the stage name for display
  createdAt   DateTime @default(now())

  @@index([orderId, createdAt])
}

// ============================================
// ADMIN NOTES (Stage-level admin details)
// ============================================

model StageAdminNote {
  id          String        @id @default(cuid())
  stageId     String
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type        AdminNoteType @default(NOTE)
  content     String        @db.Text
  authorId    String
  authorName  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([stageId, createdAt])
  @@index([orderId])
}

enum AdminNoteType {
  NOTE
  COMMENT
  STATUS_DETAIL
  CHANGE_LOG
}

// ============================================
// FILE ATTACHMENTS
// ============================================

model OrderAttachment {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileName     String
  fileType     String   // MIME type
  fileSize     Int      // bytes
  storagePath  String   // path in Supabase Storage bucket
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([orderId])
}

// ============================================
// ORDER COMMENTS (Team discussion)
// ============================================

model OrderComment {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  authorId   String
  authorName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orderId, createdAt])
}

// ============================================
// ALERTS & NOTIFICATIONS
// ============================================

model Alert {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Alert details
  title           String
  message         String   @db.Text
  severity        Severity @default(INFO)

  // Related entities (optional)
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  factoryId       String?
  factory         Factory? @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  conversationId  String?
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  // Status
  read            Boolean  @default(false)
  resolved        Boolean  @default(false)
  resolvedAt      DateTime?
  resolvedBy      String?

  createdAt       DateTime @default(now())

  @@index([organizationId, read])
  @@index([organizationId, createdAt])
  @@index([projectId])
  @@index([orderId])
  @@index([factoryId])
  @@index([conversationId])
}

enum Severity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// ============================================
// NOTIFICATION PREFERENCES
// ============================================

model NotificationPreference {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderStatusEnabled      Boolean  @default(true)
  delayAlertEnabled       Boolean  @default(true)
  disruptionAlertEnabled  Boolean  @default(true)
  weeklyDigestEnabled     Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ============================================
// CHAT & MESSAGING
// ============================================

model Conversation {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Participants
  participants    ConversationParticipant[]
  messages        Message[]
  alerts          Alert[]

  // Optional: Link to specific order or factory
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  factoryId       String?
  factory         Factory? @relation(fields: [factoryId], references: [id], onDelete: SetNull)

  // Chat type & category
  type            ConversationType @default(GENERAL)
  category        String?

  // Metadata
  name            String?
  subject         String?
  lastMessageAt   DateTime?

  // Request relation
  request         Request?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Read status
  lastReadAt      DateTime?
  unreadCount     Int      @default(0)

  // Notification preferences for this conversation
  muted           Boolean  @default(false)
  pinned          Boolean  @default(false)
  notifyReplies   Boolean  @default(true)
  notifyMentions  Boolean  @default(true)

  // Typing indicator — updated on each keystroke, considered "typing" if within last 3s
  typingAt        DateTime?

  createdAt       DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId        String?
  sender          User?    @relation(fields: [senderId], references: [id])

  content         String   @db.Text
  messageType     MessageType @default(TEXT)

  // For request approvals
  requestAction   RequestAction?

  // Threading
  parentId        String?
  parent          Message?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies         Message[] @relation("MessageThread")
  threadCount     Int       @default(0)

  // Soft delete
  deletedAt       DateTime?

  // Pinning
  pinnedAt        DateTime?
  pinnedById      String?

  // Forwarding
  forwardedFromId String?
  forwardedFrom   Message?  @relation("MessageForward", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwards        Message[] @relation("MessageForward")

  // Read tracking
  readBy          MessageRead[]

  // Reactions
  reactions       MessageReaction[]

  // File attachments
  attachments     MessageAttachment[]

  createdAt       DateTime @default(now())
  editedAt        DateTime?

  @@index([conversationId])
  @@index([createdAt])
  @@index([parentId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String

  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model MessageAttachment {
  id           String   @id @default(cuid())
  messageId    String
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName     String
  fileType     String
  fileSize     Int
  storagePath  String
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([messageId])
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
}

enum MessageType {
  TEXT            // Regular text message
  SYSTEM          // System-generated (e.g., "User joined")
  REQUEST         // Request notification
  APPROVAL        // Approval/rejection of request
  BOT             // Bot-generated message (Sourcy Agent)
}

enum ConversationType {
  GENERAL         // Default team chat
  SUPPORT         // Support chat with Sourcy Agent
  FACTORY         // Factory communication
  DIRECT          // 1:1 direct messages
}

enum RequestAction {
  APPROVED
  REJECTED
  PENDING_INFO    // Admin needs more information
}

// EMAIL LOGGING
// ============================================

model EmailLog {
  id        String   @id @default(cuid())
  toEmail   String
  fromEmail String
  subject   String
  status    String   // SENT, FAILED
  resendId  String?
  error     String?
  sentAt    DateTime @default(now())
}

// ============================================
// USER PRESENCE
// ============================================

model UserPresence {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeen      DateTime @default(now())
  status        String?  // null = auto-detect, "online"/"away"/"busy" = manual override
  customMessage String?  // Slack-style status text (max 100 chars)

  @@index([lastSeen])
}

// ============================================
// REQUESTS (Order/Factory approval workflow)
// ============================================

enum RequestType {
  ORDER_REQUEST
  FACTORY_REQUEST
  ORDER_EDIT_REQUEST
  FACTORY_EDIT_REQUEST
  ORDER_DELETE_REQUEST
  FACTORY_DELETE_REQUEST
}

enum RequestStatus {
  PENDING
  IN_REVIEW
  NEEDS_INFO
  APPROVED
  REJECTED
  CANCELLED
}

model Request {
  id              String        @id @default(cuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  requesterId     String
  requester       User          @relation("RequestsCreated", fields: [requesterId], references: [id])

  type            RequestType
  status          RequestStatus @default(PENDING)
  data            Json          // Stores order/factory form data as flexible JSON

  // Review
  reviewedById    String?
  reviewedBy      User?         @relation("RequestsReviewed", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  reviewNote      String?       @db.Text

  // Target entities (created after approval for CREATE, or referenced for EDIT/DELETE)
  targetOrderId   String?  @unique
  targetOrder     Order?   @relation(fields: [targetOrderId], references: [id], onDelete: SetNull)
  targetFactoryId String?  @unique
  targetFactory   Factory? @relation(fields: [targetFactoryId], references: [id], onDelete: SetNull)

  // Chat thread
  conversationId  String?  @unique
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, status])
  @@index([projectId])
  @@index([requesterId])
}

// ============================================
// CUSTOM CHARTS
// ============================================

enum ChartType {
  BAR
  LINE
  PIE
  AREA
  RADAR
  STACKED_BAR
}

enum ChartVisibility {
  PERSONAL
  SHARED
}

model CustomChart {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creatorId      String
  title          String
  chartType      ChartType
  dataSource     String          // e.g. "status-breakdown", "trends", "lead-time"
  metric         String          // e.g. "ordersByStatus", "ordersOverTime"
  config         Json            // axes, colors, filters, dateRange, showTrendLine
  visibility     ChartVisibility @default(PERSONAL)
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, visibility])
  @@index([projectId])
  @@index([creatorId])
}
